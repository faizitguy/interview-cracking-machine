# ICM server environment — copy to server/.env and fill in.
# (.env is git-ignored; never commit real keys.)

# Supabase (single-user store). From your project's API settings,
# or from `supabase start` output if running locally.
SUPABASE_URL=
# Prefer the service_role key on the trusted local server:
SUPABASE_SERVICE_KEY=
# Optional fallback if you only have the anon key:
SUPABASE_ANON_KEY=

# Optional: override the server port (default 4317).
# ICM_PORT=4317
